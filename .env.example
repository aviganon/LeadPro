# Copy to .env.local and fill values. See README for security notes.

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-side Firestore / Auth (JSON string from Firebase Console → Service accounts)
FIREBASE_SERVICE_ACCOUNT_KEY=

# AES-GCM key for Facebook tokens (openssl rand -base64 32)
TOKEN_ENCRYPTION_KEY=
# ENCRYPTION_KEY=

# Upstash Redis (optional — production rate limits across serverless instances)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Facebook App
NEXT_PUBLIC_FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Anthropic (AI post generation)
ANTHROPIC_API_KEY=

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
# RSS/Atom feeds (comma-separated). Google Alerts: use the RSS link from your alert.
LEAD_RSS_FEED_URLS=
LEAD_RSS_STRICT_KEYWORDS=0

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
