# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-side Firestore / Auth (download JSON from Firebase Console → Service accounts)
FIREBASE_SERVICE_ACCOUNT_KEY=

# AES-GCM key for Facebook tokens (openssl rand -base64 32) — same value in Cloud Functions env
TOKEN_ENCRYPTION_KEY=
# Optional alias for TOKEN_ENCRYPTION_KEY (legacy / alternate name)
# ENCRYPTION_KEY=

# Upstash Redis (optional — distributed API rate limiting; omit to use in-memory limiter in dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Facebook — רק App ID כאן (מספר 14–18 ספרות מ-Settings → Basic). לא App Secret ולא מרכאות.
NEXT_PUBLIC_FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Anthropic (for AI post generation + optional lead rescoring on scrape)
ANTHROPIC_API_KEY=
# 1 = אחרי כל איסוף לידים — שינוי qualityScore עם Claude (עולה טוקנים; מומלץ לבדוק בפרודקשן)
LEAD_AI_SCORING=0

# Telegram Bot (optional — הודעות שנשלחות לבוט ומתאימות למילות מפתח)
TELEGRAM_BOT_TOKEN=

# הזנות RSS/Atom (אופציונלי) — כתובות מופרדות בפסיקים; Google Alerts: אחרי יצירת התראה העתק את קישור ה-RSS
# דוגמה: https://www.google.com/alerts/feeds/01234567890123456789/01234567890123456789
LEAD_RSS_FEED_URLS=
# אם 1 — רק פריטים שמכילים אחת ממילות החיפוש של האיסוף (בכותרת/תקציר)
LEAD_RSS_STRICT_KEYWORDS=0

# Stripe (billing)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
